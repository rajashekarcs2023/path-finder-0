# path-finder-0 environment configuration
#
# The demo runs FULLY without any of these set (deterministic fallback mode).
# Add them only to enable real AI reasoning and/or real browser navigation.

# Enable real OpenAI-powered persona reasoning + fix generation.
# Without this key, path-finder-0 uses the deterministic fallback agent.
OPENAI_API_KEY=

# Model used when OPENAI_API_KEY is present.
OPENAI_MODEL=gpt-4o-mini

# Set to "true" to drive a real Playwright Chromium browser through the demo
# site. Requires `npm run playwright:install` first. When false/unset, runs use
# the deterministic fallback journeys (recommended for reliable demos).
USE_BROWSER_AGENT=false

# Set to "false" to watch the real browser navigate (only with USE_BROWSER_AGENT=true).
HEADLESS=true

# Base URL the browser agent points at when crawling /demo-site.
# Defaults to http://localhost:3000 in development.
PATHFINDER_BASE_URL=http://localhost:3000

# ---- Live URL testing with browser-use + Gemini (the "real" engine) ----
# When a Live URL is entered in setup, path-finder-0 can drive the open-source
# browser-use agent (real autonomous browser + Gemini) against the real site.
# If this is off or fails, live runs fall back to the in-process Playwright+OpenAI
# agent, then to a generic verdict — the app never breaks.
USE_BROWSER_USE=false

# Absolute path to a Python interpreter in a venv that has `browser-use` installed.
# e.g. /Users/you/path-finder-0/agent/.venv/bin/python
PYTHON_BIN=

# Gemini API key used by browser-use (or set GOOGLE_API_KEY).
GEMINI_API_KEY=
GEMINI_MODEL=gemini-3.5-flash

# Tuning for live browser-use runs.
BROWSER_USE_MAX_STEPS=7
BROWSER_USE_CONCURRENCY=2
BROWSER_USE_TIMEOUT_MS=110000
